{
  "name": "@orbidicom/core",
  "version": "0.8.0",
  "description": "Framework-agnostic engine for a modern, mobile-responsive DICOM viewer: Cornerstone3D setup, pluggable PACS/local DataSources, tools and W/L presets.",
  "license": "MIT",
  "homepage": "https://github.com/docorbitapp/orbidicom#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/docorbitapp/orbidicom.git",
    "directory": "packages/core"
  },
  "bugs": "https://github.com/docorbitapp/orbidicom/issues",
  "keywords": [
    "dicom",
    "dicomweb",
    "cornerstone3d",
    "medical-imaging",
    "pacs",
    "viewer"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run"
  },
  "dependencies": {
    "@cornerstonejs/core": "5.0.13",
    "@cornerstonejs/dicom-image-loader": "5.0.13",
    "@cornerstonejs/nifti-volume-loader": "5.0.13",
    "@cornerstonejs/tools": "5.0.13",
    "dicom-parser": "^1.8.21",
    "dicomweb-client": "^0.11.2"
  }
}
