{
  "name": "@orbidicom/vue",
  "version": "0.6.1",
  "description": "Modern, mobile-responsive, multilingual Vue 3 UI for the OrbiDICOM viewer: toolbar, series rail, selectable grids, on-image metadata overlay, metadata reader, theming and live i18n (EN/TR/DE/ES).",
  "license": "MIT",
  "homepage": "https://github.com/docorbitapp/orbidicom#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/docorbitapp/orbidicom.git",
    "directory": "packages/vue"
  },
  "bugs": "https://github.com/docorbitapp/orbidicom/issues",
  "keywords": [
    "dicom",
    "vue",
    "vue3",
    "medical-imaging",
    "viewer",
    "cornerstone3d"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./theme.css": "./src/theme.css"
  },
  "files": [
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vue-tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@orbidicom/core": "workspace:*",
    "pdfjs-dist": "^6.0.227"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.0",
    "@vue/test-utils": "^2.4.0",
    "jsdom": "^25.0.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.1.0"
  }
}
