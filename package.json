{
  "name": "orbidicom-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.34.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm --filter @orbidicom/core build && pnpm --filter @orbidicom/vue build && pnpm --filter @orbidicom/demo build && pnpm --filter orbidicom build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "typecheck": "tsc -b --pretty",
    "demo": "pnpm --filter @orbidicom/demo dev",
    "changeset": "changeset",
    "release": "pnpm -r publish --access public --no-git-checks"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.0",
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^9.0.0",
    "globals": "^17.7.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.1.0"
  }
}
